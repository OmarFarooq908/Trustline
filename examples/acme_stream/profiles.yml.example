# Copy to profiles.yml (gitignored). duckdb_path is relative to this file's directory.
# When profiles.yml lives at the repo root, demo.duckdb still resolves via the ACME fallback.

default:
  target: duckdb
  database: main
  schema: main
  duckdb_path: demo.duckdb

acme_prod:
  target: snowflake
  database: ANALYTICS
  schema: ML_STAGING
