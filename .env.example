# Trustline environment variables (copy to .env — never commit .env)

# Logging
TRUSTLINE_LOG_LEVEL=INFO

# Integration tests (set to 1 to enable warehouse integration tests)
# TRUSTLINE_RUN_INTEGRATION=0

# Snowflake (optional — integration tests only)
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=

# Notifications (optional)
# SLACK_WEBHOOK_URL=
